{
  "version": 2,
  "name": "rsd-qualify",
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/public/pages/$1"
    },
    {
      "src": "/",
      "dest": "/public/pages/rsd-funnel-page-01-hero.html"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/public/pages/$1"
    }
  ]
}
