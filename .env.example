# ─────────────────────────────────────────────────────────────
#  RSD Qualify — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────────

# ── GHL Webhook ──────────────────────────────────────────────
# From GHL: Automation → New Workflow → Webhook Trigger → Copy URL
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/XXXXXXXXXXXXXXXX

# ── Google Drive ─────────────────────────────────────────────
# Service account credentials (from Google Cloud Console)
# Create a service account, download the JSON key, paste values below.
GOOGLE_CLIENT_EMAIL=rsd-qualify@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Drive Folder ID — the parent "RSD Qualifications" folder
# Create this folder in Drive, share it with the service account email,
# then paste the folder ID from the URL: drive.google.com/drive/folders/FOLDER_ID
GOOGLE_DRIVE_PARENT_FOLDER_ID=1ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefg

# ── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
